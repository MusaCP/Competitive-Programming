#include <bits/stdc++.h>
using namespace std;

#define ll long long
#define pb push_back
#define all(x) (x).begin(), (x).end()

#define nl '\n'


template<typename T>
istream& operator>>(istream &in, vector<T> &v){
    for(auto &x:v) in>>x;
    return in;
}

void solve(){
   
    string s;
    cin>>s;

    sort(all(s));

    if(s[0]==s[s.size()-1]){

        cout << 0 << nl;

    }
    else{
        cout <<( 2* s.length() ) -2 << nl;
    }

}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int test_case;
    cin >> test_case;
    while(test_case--) {
      solve();

    }

    return 0;
}
